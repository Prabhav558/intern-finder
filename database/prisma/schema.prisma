// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER MODELS ====================

enum Role {
  STUDENT
  ADMIN
  COMPANY
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  passwordHash       String?
  role               Role      @default(STUDENT)
  profilePhotoUrl    String?
  isVerified         Boolean   @default(false)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  studentProfile     StudentProfile?
  company            Company?
  applications       Application[]
  bookmarks          Bookmark[]
  notifications      Notification[]
  badges             StudentBadge[]
  deadlineReminders  DeadlineReminder[]
  opportunities      Opportunity[] @relation("CreatedBy")
  reviews            ReviewFeedback[]
}

model StudentProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  rollNo            String?
  branch            String?
  graduationYear    Int?
  cgpa              Float?
  skills            String[]
  interests         String[]
  resumeUrl         String?
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  bio               String?
  location          String?
  badgesEarned      Json?     @default("[]")
  profileScore      Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                String    @id @default(cuid())
  userId            String    @unique
  companyName       String
  logoUrl           String?
  website           String?
  description       String?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunities     Opportunity[]

  @@index([userId])
}

// ==================== OPPORTUNITY MODELS ====================

enum OpportunityType {
  INTERNSHIP
  HACKATHON
  RESEARCH
  SCHOLARSHIP
  WORKSHOP
  JOB
  COMPETITION
}

enum OpportunityMode {
  REMOTE
  ONSITE
  HYBRID
}

model Opportunity {
  id                  String    @id @default(cuid())
  title               String
  description         String    @db.Text
  companyName         String
  organizer           String?
  type                OpportunityType
  domains             String[]
  deadline            DateTime
  eligibilityCriteria Json?
  stipendPrize        String?
  applicationLink     String?
  tags                String[]
  isVerified          Boolean   @default(false)
  isActive            Boolean   @default(true)
  externalUrl         String?
  viewsCount          Int       @default(0)
  location            String?
  mode                OpportunityMode @default(REMOTE)
  requiredSkills      String[]
  minCgpa             Float?
  allowedBranches     String[]
  allowedYears        Int[]
  postedBy            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  createdByUser       User?     @relation("CreatedBy", fields: [postedBy], references: [id])
  applications        Application[]
  bookmarks           Bookmark[]
  deadlineReminders   DeadlineReminder[]

  @@index([postedBy])
  @@index([deadline])
  @@index([type])
  @@index([isActive])
}

// ==================== APPLICATION MODELS ====================

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  SHORTLISTED
  SELECTED
  REJECTED
  WITHDRAWN
}

model Application {
  id                String    @id @default(cuid())
  studentId         String
  opportunityId     String
  status            ApplicationStatus @default(PENDING)
  resumeUrl         String?
  coverLetter       String?   @db.Text
  notes             String?
  appliedAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  student           User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([studentId, opportunityId])
  @@index([studentId])
  @@index([opportunityId])
  @@index([status])
}

model Bookmark {
  id                String    @id @default(cuid())
  studentId         String
  opportunityId     String
  createdAt         DateTime  @default(now())

  // Relations
  student           User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([studentId, opportunityId])
  @@index([studentId])
  @@index([opportunityId])
}

// ==================== NOTIFICATION MODELS ====================

enum NotificationType {
  DEADLINE_REMINDER
  APPLICATION_STATUS
  NEW_OPPORTUNITY
  SYSTEM_ALERT
  BADGE_EARNED
  RECOMMENDATION
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  message           String
  isRead            Boolean   @default(false)
  metadata          Json?
  createdAt         DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ==================== BADGE MODELS ====================

model Badge {
  id                String    @id @default(cuid())
  name              String    @unique
  description       String
  iconUrl           String?
  criteria          Json?
  tier              Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  students          StudentBadge[]
}

model StudentBadge {
  id                String    @id @default(cuid())
  studentId         String
  badgeId           String
  earnedAt          DateTime  @default(now())

  // Relations
  student           User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge             Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@index([studentId])
  @@index([badgeId])
}

// ==================== REMINDER MODELS ====================

enum ReminderChannel {
  EMAIL
  SMS
  PUSH
}

model DeadlineReminder {
  id                String    @id @default(cuid())
  studentId         String
  opportunityId     String
  remindAt          DateTime
  channel           ReminderChannel
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  student           User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([opportunityId])
  @@index([remindAt])
}

// ==================== SCRAPER MODELS ====================

model ScrapeSource {
  id                String    @id @default(cuid())
  name              String    @unique
  url               String
  type              String
  lastScrapedAt     DateTime?
  isActive          Boolean   @default(true)
  scheduleCron      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ==================== FEEDBACK & ANALYTICS ====================

model ReviewFeedback {
  id                String    @id @default(cuid())
  userId            String
  recommendationId  String?
  feedback          String    @db.Text
  sentiment         String?
  createdAt         DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== SESSION MANAGEMENT ====================

model Session {
  id                String    @id @default(cuid())
  userId            String
  token             String    @unique
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  @@index([userId])
}
